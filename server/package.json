{
  "name": "findu",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --require tsconfig-paths/register --watch .env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev",
    "lint": "eslint . --ext .ts",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose",
    "seed:users": "ts-node -r tsconfig-paths/register src/scripts/seed/seed.ts",
    "seed:jac352": "ts-node -r tsconfig-paths/register src/scripts/seed/seed-jac352.ts",
    "cleanup:jac352": "ts-node -r tsconfig-paths/register src/scripts/seed/cleanupJac352.ts",
    "cleanup:users": "ts-node -r tsconfig-paths/register src/scripts/seed/cleanupSeed.ts",
    "cleanup:all-likes-matches": "ts-node -r tsconfig-paths/register src/scripts/likes/cleanupLikesMatches.ts",
    "seed:uni": "ts-node -r tsconfig-paths/register src/scripts/seed/setupUniversities.ts",
    "getuser": "ts-node -r tsconfig-paths/register src/scripts/debug/getuser.ts",
    "test:setup-likes": "ts-node -r tsconfig-paths/register src/scripts/likes/testLikes.ts",
    "create:test-likes": "ts-node -r tsconfig-paths/register src/scripts/likes/createTestLikes.ts",
    "create:mutual-likes": "ts-node -r tsconfig-paths/register src/scripts/likes/createMutualTestLikes.ts",
    "show:likes": "ts-node -r tsconfig-paths/register src/scripts/likes/showTestLikes.ts",
    "check:matches": "ts-node -r tsconfig-paths/register src/scripts/debug/checkMatches.ts",
    "cleanup:test-likes": "ts-node -r tsconfig-paths/register src/scripts/likes/cleanupTestData.ts",
    "debug:discover": "ts-node -r tsconfig-paths/register src/scripts/debug/debugDiscover.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@better-auth/cli": "^1.4.0",
    "@prisma/client": "^6.12.0",
    "@supabase/supabase-js": "^2.86.2",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.4.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@eslint/js": "^9.31.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/ioredis": "^4.28.10",
