# App Environment
EXPO_PUBLIC_ENV=development

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# API Base URL
EXPO_PUBLIC_API_URL=http://localhost:3000

EXPO_PUBLIC_ENABLE_AUTH=true
EXPO_PUBLIC_ENABLE_PERSISTENCE=false
OTP_EXPIRATION_SECONDS=600

# Token expiration (in seconds)
EXPO_PUBLIC_ACCESS_TOKEN_EXPIRY=3600
EXPO_PUBLIC_SESSION_EXPIRY=2592000
EXPO_PUBLIC_AUTO_REFRESH_THRESHOLD=300
EXPO_PUBLIC_AUTO_REFRESH_ENABLED=true

# Security toggles
EXPO_PUBLIC_CLEAR_TOKENS_ON_BACKGROUND=true
EXPO_PUBLIC_REQUIRE_BIOMETRIC=false
